{
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.build.fromWorkspaceFolder": true,
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.search.rootFiles.include": ["projects/**/*.tex"],
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (repo)",
      "tools": ["latexmk"]
    }
  ],
  "latex-workshop.latex.recipe.default": "latexmk (repo)",
  "editor.defaultFormatter": "lenagain.latexindent",
  "[latex]": {
    "editor.defaultFormatter": "lenagain.latexindent",
    "editor.formatOnSave": true
  },
  "[tex]": {
    "editor.defaultFormatter": "lenagain.latexindent",
    "editor.formatOnSave": true
  }
}
